{
  "builds": [
    {
      "src": "frontend/package.json",
      "use": "@vercel/static-build",
      "config": { "distDir": "build" }
    },
    {
      "src": "api/contact.js",
      "use": "@vercel/node"
    },
    {
      "src": "api/*.py",
      "use": "@vercel/python"
    }
  ],
  "routes": [
    { "src": "/api/contact",   "dest": "/api/contact.js" },
    { "src": "/api/analytics", "dest": "/api/analytics.py" },
    { "src": "/api/health",    "dest": "/api/health.py" },
    { "src": "/(.*)",          "dest": "/frontend/build/index.html" }
  ]
}
